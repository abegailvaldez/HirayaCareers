@model HirayaCareers.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Register";
}

<section class="auth-page">
    <div class="container">
        <div class="auth-card">
            <div class="text-center mb-3">
                <p class="landing-label">Get Started</p>

                <h1 class="auth-title">Join HirayaCareers</h1>

                <p class="auth-subtitle">
                    Create your account to start exploring opportunities.
                </p>
            </div>

            <form asp-action="Register" asp-controller="Account" method="post">
                <div class="row g-1">
                    <div class="col-md-6">
                        <label class="form-label">First Name</label>
                        <input asp-for="FirstName" class="form-control" placeholder="Enter first name" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Last Name</label>
                        <input asp-for="LastName" class="form-control" placeholder="Enter last name" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Email Address</label>
                        <input asp-for="Email" class="form-control" placeholder="Enter email address" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Password</label>
                        <input asp-for="Password" type="password" class="form-control" placeholder="Enter password" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Confirm Password</label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirm password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label class="form-label d-block">Account Type</label>

                        <div class="role-options">
                            <label class="role-card">
                                <input asp-for="Role" type="radio" value="JobSeeker" />
                                <span>Job Seeker</span>
                            </label>

                            <label class="role-card">
                                <input asp-for="Role" type="radio" value="Employer" />
                                <span>Employer</span>
                            </label>

                            <span asp-validation-for="Role" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-12 d-grid mt-3">
                        <button type="submit" class="btn btn-primary btn-lg">
                            Create Account
                        </button>
                    </div>
                </div>
            </form>

            <p class="text-center mt-3 mb-0">
                Already have an account?
                <a asp-controller="Account" asp-action="Login">Login here</a>
            </p>
        </div>
    </div>
</section>