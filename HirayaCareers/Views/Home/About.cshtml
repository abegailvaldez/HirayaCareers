@{
    ViewData["Title"] = "About Us";
}

<section class="about-page">
    <div class="container">
        <div class="text-center mb-4">
            <p class="landing-label">About HirayaCareers</p>

            <h1 class="about-title">Connecting People with Opportunities</h1>

            <p class="about-text">
                HirayaCareers is an online job search platform designed to help job seekers
                and employers connect in one secure and user-friendly system.
            </p>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-md-6">
                <div class="about-card h-100">
                    <h5>🎯 Mission</h5>
                    <p>
                        To connect talented individuals with trusted employers through
                        a secure and user-friendly online job platform.
                    </p>
                </div>
            </div>

            <div class="col-md-6">
                <div class="about-card h-100">
                    <h5>💡 Vision</h5>
                    <p>
                        To become a reliable digital career platform that empowers job seekers
                        and organisations to build meaningful professional connections.
                    </p>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-6">
                <div class="about-card h-100">
                    <h5>Platform Features</h5>
                    <ul>
                        <li>Secure registration and login</li>
                        <li>Job browsing after user authentication</li>
                        <li>Simple job application process</li>
                        <li>Employer job posting and applicant management</li>
                    </ul>
                </div>
            </div>

            <div class="col-md-6">
                <div class="about-card h-100">
                    <h5>Technologies Used</h5>
                    <ul>
                        <li>ASP.NET Core MVC</li>
                        <li>Entity Framework Core</li>
                        <li>Azure SQL Database</li>
                        <li>Azure App Service</li>
                        <li>Git and GitHub</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>