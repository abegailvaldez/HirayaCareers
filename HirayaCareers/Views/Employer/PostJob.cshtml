@model HirayaCareers.Models.Job
@{
    ViewData["Title"] = "Post Job";
}

<section class="auth-page">
    <div class="container">
        <div class="auth-card">
            <div class="text-center mb-3">
                <p class="landing-label">Post New Job</p>
                <h1 class="auth-title">Create a Job Listing</h1>
                <p class="auth-subtitle">Add job details for applicants to view.</p>
            </div>

            <form asp-action="PostJob" asp-controller="Employer" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="row g-2">
                    <div class="col-md-6">
                        <label class="form-label">Job Title</label>
                        <input asp-for="Title" class="form-control" placeholder="Enter job title" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Company Name</label>
                        <input asp-for="CompanyName" class="form-control" placeholder="Company name" />
                        <span asp-validation-for="CompanyName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Location</label>
                        <input asp-for="Location" class="form-control" placeholder="Location" />
                        <span asp-validation-for="Location" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Employment Type</label>
                        <input asp-for="EmploymentType" class="form-control" placeholder="Full-time / Part-time" />
                        <span asp-validation-for="EmploymentType" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Job Description</label>
                        <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Requirements</label>
                        <textarea asp-for="Requirements" class="form-control" rows="5"></textarea>
                        <span asp-validation-for="Requirements" class="text-danger"></span>
                    </div>

                    <div class="col-12 d-grid mt-3">
                        <button type="submit" class="btn btn-primary btn-lg">
                            Publish Job
                        </button>
                    </div>
                </div>
            </form>

            <p class="text-center mt-3 mb-0">
                <a asp-controller="Employer" asp-action="Dashboard">Back to Dashboard</a>
            </p>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}